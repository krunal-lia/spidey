# PostgreSQL connection string
# Local dev: docker run -e POSTGRES_PASSWORD=postgres -p 5432:5432 postgres
# Managed: get from Neon (neon.tech) or Supabase (supabase.com) — both have free tiers
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/spidey

# Set to 'production' to disable desktop notifications (required for K8s)
SPIDEY_ENV=development

# Server port
PORT=3000
